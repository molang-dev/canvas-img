{
  "name": "canvas-img",
  "version": "0.3.3",
  "description": "Cross-origin image drawing library for Canvas",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/molang-dev/canvas-img.git"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "canvas",
    "drawImageCORS",
    "canvas-img",
    "cross-origin"
  ],
  "author": "molang",
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
